# Server
SERVER_PORT=8080
SERVER_MODE=debug     # debug | release

# Database
DB_DRIVER=sqlc        # sqlc | gorm
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=myapp
DB_SSL_MODE=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2

# Auth - select provider
AUTH_PROVIDER=jwt     # jwt | keycloak

# JWT (only when AUTH_PROVIDER=jwt)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRY=24h
# JWT_ALGORITHM=RS256
# JWT_PRIVATE_KEY_FILE=keys/private.pem
# JWT_PUBLIC_KEY_FILE=keys/public.pem
# JWT_KEY_ID=key-1

# Keycloak (only when AUTH_PROVIDER=keycloak)
KEYCLOAK_HOST=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# Logging
LOG_LEVEL=debug       # debug | info | warn | error
LOG_FORMAT=console    # console | json
